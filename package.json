{
  "name": "meetizy",
  "version": "1.0.0",
  "description": "Assistant de réunions et d'appels avec transcription temps réel",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:linux": "npm run build && electron-builder --linux",
    "generate-pdfs": "node generate-pdfs.js"
  },
  "build": {
    "appId": "com.meetizy.app",
    "productName": "Meetizy",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  },
  "keywords": [
    "transcription",
    "meetings",
    "assistant"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "axios": "^1.6.2",
    "chart.js": "^4.4.1",
    "date-fns": "^4.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^26.8.1",
    "markdown-pdf": "^11.0.0",
    "md-to-pdf": "^5.2.5",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
