# Backend Configuration
PORT=3001
NODE_ENV=development

# Clé API OpenAI (VOTRE clé centralisée)
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Secret pour authentification
JWT_SECRET=votre-secret-jwt-super-securise-changez-moi

# Database (optionnel pour démarrer, peut utiliser JSON pour début)
# DATABASE_URL=postgresql://user:password@localhost:5432/meetizy

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Features Flags
ENABLE_AI_FEATURES=true
ENABLE_ANALYTICS=true
